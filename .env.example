# ── Grand Nirwana Hotel PMS — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
# =============================================================================

# ── Security ──────────────────────────────────────────
# Generate a new key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-ME-generate-a-new-random-key

# Set to False in production!
DEBUG=True

# ── Database ──────────────────────────────────────────
# Leave DB_PASSWORD empty to use SQLite for local development (easiest).
# Fill in all DB_ values below to use PostgreSQL (Supabase).
#
# DB_NAME=postgres
# DB_USER=postgres.your-supabase-project-id
# DB_PASSWORD=your-supabase-password
# DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
# DB_PORT=6543

# ── Hotel Configuration ───────────────────────────────
HOTEL_NAME=Grand Nirwana Hotel
HOTEL_TAX_RATE=10
HOTEL_SERVICE_CHARGE=11
TIMEZONE=Asia/Pontianak

# ── Allowed Hosts ─────────────────────────────────────
# Add your domain here if deploying (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
